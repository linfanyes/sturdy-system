# ===== 服务 =====
# 后端监听端口
PORT=3000
# 前端/小程序允许的来源（逗号分隔，生产填小程序/域名）
CORS_ORIGIN=*

# ===== 数据库（腾讯云数据库 MySQL / TencentDB for MySQL） =====
# 生产部署：填腾讯云数据库 MySQL 的连接地址。
#   - 云托管与云数据库在同一 VPC/地域时，用「内网地址」（延迟低、免费、更安全）
#   - 本地联调或跨网络时，用「外网地址」（需在云数据库安全组放行来源 IP）
# 本地开发想用本机容器 MySQL：见 docker-compose.local.yml，DB_HOST 填 127.0.0.1
DB_HOST=your-tencentdb-host.rds.tencent.com
DB_PORT=3306
DB_USERNAME=gardener
DB_PASSWORD=your_tencentdb_password
DB_DATABASE=gardener
# 公网连接腾讯云数据库时设为 true 开启 SSL（内网/VPC 连接保持 false 即可）
DB_SSL=false
# 开发期自动建表；生产建议改为 false 并用 migration
DB_SYNCHRONIZE=true
# ===== MySQL 8.0 兼容性说明 =====
# 腾讯云数据库 MySQL 8.0 默认认证插件为 caching_sha2_password。
# 本项目使用 mysql2 3.x：非 TLS 连接时，客户端会自动向服务端请求 RSA 公钥完成认证，
# 无需 allowPublicKeyRetrieval 之类的额外配置（该选项在 mysql2 3.x 中已不存在）。
# 若仍报 ER_NOT_SUPPORTED_AUTH_MODE，可在云数据库控制台将该账号改为
#   ALTER USER 'gardener'@'%' IDENTIFIED WITH mysql_native_password BY '密码';
# 或保持 caching_sha2_password 并启用 DB_SSL=true（公网）。

# ===== JWT =====
# 请务必改成随机长字符串（可用 `openssl rand -base64 48` 生成）
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=30d

# ===== 超级管理员账号 =====
# 默认账号 admin/admin 极不安全，部署前必须修改为强口令！
SUPER_ADMIN_USER=admin
SUPER_ADMIN_PASSWORD=admin

# ===== 微信小程序 =====
# 微信公众平台 -> 开发管理 -> 开发设置 中获取
WECHAT_APPID=wx_your_appid
WECHAT_SECRET=your_wechat_secret

# ===== 集中配置默认值（可被数据库中的 app_config 覆盖） =====
# 默认任教学科（逗号分隔）
DEFAULT_SUBJECTS=语文,数学,英语,科学,品德,音乐,美术,体育,综合实践,信息技术
# 小程序登录码（简单校验，可后端修改）
LOGIN_CODE=1314520
# 默认 AI 配置（密钥仅存后端；此处为初始种子，可在后台修改）
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=
AI_TEXT_MODEL=qwen-plus
AI_VISION_MODEL=qwen-vl-plus
AI_TEMPERATURE=0.7
AI_NAME=小林子
AI_SYSTEM_PROMPT=你是一位耐心、专业的中国中小学班主任助手。
