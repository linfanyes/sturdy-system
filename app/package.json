{
  "name": "trace",
  "private": true,
  "version": "0.0.0",
  "description": "园丁工作台 · 教师专用桌面端",
  "author": "园丁工作台",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "check": "vue-tsc -b",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css,json}\"",
    "stylelint": "stylelint \"src/**/*.{vue,css}\"",
    "stylelint:fix": "stylelint \"src/**/*.{vue,css}\" --fix",
    "electron:dev": "electron .",
    "electron:build": "electron-builder",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,vue}": [
      "stylelint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "docx": "^9.7.1",
    "electron-packager": "^17.1.2",
    "jszip": "^3.10.1",
    "lucide-vue-next": "^0.511.0",
    "marked": "^18.0.6",
    "nanoid": "^5.0.9",
    "pdfjs-dist": "^6.1.200",
    "pinia": "^2.3.0",
    "tailwind-merge": "^3.3.0",
    "vue": "^3.5.0",
    "vue-router": "^4.2.5",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/runtime-dom": "^3.5.0",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.17",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "stylelint": "^16.2.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard": "^36.0.0",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.5.0",
    "unplugin-vue-dev-locator": "^1.0.0",
    "vite": "^6.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^0.21.0",
    "vue-tsc": "^2.0.0"
  }
}
